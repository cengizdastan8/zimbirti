{
  "name": "tekpanel",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test:web": "npm run build && node scripts/web-smoke.mjs",
    "test:native": "node scripts/native-capture-smoke.mjs",
    "mobile:sync": "npm run build && cap sync android",
    "mobile:open": "cap open android",
    "android:build": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/android-build.ps1",
    "android:release": "npm run mobile:sync && powershell -NoProfile -ExecutionPolicy Bypass -File scripts/android-release-bundle.ps1",
    "android:watch": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/watch-android-capture.ps1",
    "android:fix-miui": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/fix-miui-notification.ps1"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "simple-icons": "^16.23.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "overrides": {
    "postcss": "^8.5.15"
  }
}
